# Demo Maker API Keys
# Copy this file to .demo-maker/.env and add your key:
#   cp .env.example .demo-maker/.env
#
# This key never leaves your machine. It is only used for API calls
# to generate voice narration. The AI agent cannot read this file.

# ── Voice Narration ──────────────────────────────────────────────────
# ElevenLabs (voice narration — preview, narration, voice design)
# Get your key: https://elevenlabs.io/ → Profile → API Key
ELEVENLABS_API_KEY=your-key-here
